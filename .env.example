# ============================================================
# QuantTrade ML Pipeline — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ---- API Keys ----
APIFY_API_KEY=YOUR_APIFY_API_KEY

# ---- Paths ----
DATA_RAW_PATH=data/raw/eurusd_hour.csv
DATA_PROCESSED_PATH=data/processed
DB_PATH=data/db/quanttrade.db
MODEL_PATH=models
LOG_PATH=logs

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=colored

# ---- Walk-Forward Parameters ----
WF_TRAIN_DAYS=90
WF_TEST_DAYS=30
WF_STEP_DAYS=30
WF_EMBARGO_DAYS=5

# ---- ML Parameters ----
RANDOM_SEED=42
N_OPTUNA_TRIALS=50
MAX_FEATURES=50

# ---- Simulation Parameters ----
INITIAL_CAPITAL=100000
RISK_PER_TRADE=0.01
MAX_SPREAD_PIPS=3.0
SLIPPAGE_PIPS=0.5

# ---- Apify ----
APIFY_MACRO_DAYS=180
